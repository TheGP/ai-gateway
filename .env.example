# Gateway auth (used for API + dashboard)
GATEWAY_AUTH_TOKEN=your-secret-token

# Telegram alerts
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Proxies (only needed if proxy.type = webshare in providers.yaml)
WEBSHARE_API_KEY=your-webshare-key

# Google AI Studio
GEMINI_API_KEY_1=key1
GEMINI_API_KEY_2=key2
GEMINI_API_KEY_3=key3

# Groq
GROQ_API_KEY_1=key1
GROQ_API_KEY_2=key2

# Mistral
MISTRAL_API_KEY_1=key1

# Cerebras
CEREBRAS_API_KEY_1=key1

# NVIDIA NIM
NVIDIA_API_KEY_1=nvapi-xxx
